{
  "buildCommand": "cd portal && npm ci && npm run build",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/portal/assets/:file*",
      "destination": "/portal/dist/assets/:file*"
    },
    {
      "source": "/portal",
      "destination": "/portal/dist/app.html"
    },
    {
      "source": "/portal/:path*",
      "destination": "/portal/dist/app.html"
    }
  ]
}
